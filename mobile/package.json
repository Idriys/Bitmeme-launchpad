{
  "name": "bitmeme-mobile",
  "version": "1.0.0",
  "description": "Bitmeme Bitcoin Meme Coin Launchpad - Mobile App",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "web": "expo start --web",
    "start": "react-native start",
    "test": "jest",
    "build-android": "cd android && ./gradlew assembleRelease",
    "build-ios": "cd ios && xcodebuild -workspace bitmeme.xcworkspace -scheme bitmeme -configuration Release",
    "bundle-android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle",
    "bundle-ios": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle",
    "prebuild-android": "expo prebuild --platform android",
    "prebuild-ios": "expo prebuild --platform ios"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.0",
    "react-native-gesture-handler": "^2.13.0",
    "react-native-reanimated": "^3.5.0",
    "react-native-screens": "^3.26.0",
    "react-native-vector-icons": "^9.2.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native-stack": "^6.9.17",
    "axios": "^1.6.0",
    "ethers": "^6.7.1",
    "web3": "^4.1.0",
    "@react-native-async-storage/async-storage": "^1.19.3",
    "react-native-toast-message": "^2.1.5",
    "crypto": "^1.0.3",
    "expo": "^49.0.0",
    "expo-splash-screen": "^0.26.0",
    "expo-status-bar": "^1.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.21.0",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.70.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "jest": "^29.5.0",
    "metro-react-native-babel-preset": "0.73.9",
    "react-native-codegen": "0.72.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "react-native"
  }
}
