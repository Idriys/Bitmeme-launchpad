  "type": "commonjs",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "ethers": "^6.7.1",
    "web3": "^4.1.0",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "mongoose": "^7.5.0",
    "validation": "^0.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "nodemon": "^3.0.1"
  }
